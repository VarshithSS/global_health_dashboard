# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ---------------------------------------------------------------------------
# Secrets / local config
# The app reads PORT (and anything else it may need) from the environment.
# Never commit a local env file.
# ---------------------------------------------------------------------------
.env
.env.*

# ---------------------------------------------------------------------------
# Report build source — only the finished PDF is shipped
# (report/CS661_Group5_Project_Report.pdf stays tracked).
# ---------------------------------------------------------------------------
report/report.html
report/report.css
report/build_report.py
report/figures/*
# ...except the dashboard screenshot the README embeds on the repo landing page.
!report/figures/ui_overview.png

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*~

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs & scratch
# ---------------------------------------------------------------------------
*.log
